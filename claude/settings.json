{
  "theme" : "auto",
  "inputNeededNotifEnabled" : true,
  "awaySummaryEnabled" : false,
  "permissions" : {
    "allow" : [
      "Bash(gh:*)",
      "Bash(curl:*)",
      "Bash(composer:*)",
      "Bash(vendor\/bin\/phpunit:*)",
      "Bash(vendor\/bin\/pest:*)",
      "Bash(vendor\/bin\/phpstan:*)",
      "Bash(vendor\/bin\/pint:*)",
      "Bash(vendor\/bin\/rector:*)",
      "Bash(git:*)",
      "Bash(php artisan:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(yarn:*)",
      "Bash(pnpm:*)",
      "Bash(php:*)",
      "Bash(docker:*)",
      "Bash(docker-compose:*)",
      "Bash(make:*)",
      "Bash(brew:*)",
      "Bash(sed:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(echo:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(touch:*)",
      "Bash(chmod:*)",
      "Bash(pwd:*)",
      "Bash(which:*)",
      "Bash(whoami:*)",
      "Bash(date:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(diff:*)",
      "Bash(awk:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(open:*)",
      "WebSearch",
      "WebFetch",
      "mcp__laravel-boost__*",
      "mcp__chrome-devtools__*",
      "mcp__playwright__*"
    ],
    "defaultMode" : "acceptEdits"
  },
  "env" : {
    "CLAUDE_CODE_NO_FLICKER" : "1"
  },
  "model" : "opus",
  "autoCompactEnabled" : true,
  "statusLine" : {
    "command" : "bash \/Users\/michaeldulle\/.claude\/statusline-command.sh",
    "type" : "command"
  },
  "hooks" : {
    "SessionStart" : [
      {
        "matcher" : "compact|resume",
        "hooks" : [
          {
            "type" : "command",
            "command" : "bash $HOME\/.claude\/hooks\/context-recovery.sh"
          }
        ]
      },
      {
        "hooks" : [
          {
            "type" : "command",
            "command" : "bash $HOME\/.claude\/hooks\/brain-loader.sh"
          }
        ]
      }
    ],
    "PostToolUse" : [
      {
        "matcher" : "Edit|Write|MultiEdit",
        "hooks" : [
          {
            "type" : "command",
            "command" : "bash $HOME\/.claude\/hooks\/auto-format.sh"
          }
        ]
      }
    ],
    "PreToolUse" : [
      {
        "matcher" : "Bash",
        "hooks" : [
          {
            "type" : "command",
            "command" : "bash $HOME\/.claude\/hooks\/block-dangerous-commands.sh"
          },
          {
            "type" : "command",
            "command" : "bash $HOME\/.claude\/hooks\/git-workflow-guard.sh"
          }
        ]
      },
      {
        "matcher" : "Edit|Write|MultiEdit",
        "hooks" : [
          {
            "type" : "command",
            "command" : "bash $HOME\/.claude\/hooks\/protect-sensitive-files.sh"
          }
        ]
      }
    ],
    "Stop" : [
      {
        "hooks" : [
          {
            "type" : "command",
            "command" : "bash $HOME\/.claude\/hooks\/verify-done.sh"
          },
          {
            "type" : "command",
            "command" : "bash $HOME\/.claude\/hooks\/debug-scrubber.sh"
          },
          {
            "type" : "command",
            "command" : "bash $HOME\/.claude\/hooks\/require-tests.sh"
          },
          {
            "type" : "command",
            "command" : "bash $HOME\/.claude\/hooks\/focused-test-guard.sh"
          },
          {
            "type" : "command",
            "command" : "bash $HOME\/.claude\/hooks\/env-drift.sh"
          },
          {
            "type" : "command",
            "command" : "bash $HOME\/.claude\/hooks\/product-doc-lint.sh"
          }
        ]
      }
    ]
  },
  "agentPushNotifEnabled" : true,
  "enabledPlugins" : {
    "feature-dev@claude-plugins-official" : true,
    "code-simplifier@claude-plugins-official" : true,
    "security-guidance@claude-plugins-official" : true,
    "remember@claude-plugins-official" : true,
    "claude-md-management@claude-plugins-official" : true
  },
  "fastMode" : true
}