#!/usr/bin/env bash

alias brewup='brew update && brew upgrade && brew cleanup'

# The install guards and cask version helpers (cask, formula, mas_install,
# cask_version_available, ...) live in provisioning/mac/helpers.sh — source the
# single canonical copy so interactive shells and provisioning never drift.
# ~/.provisioning is symlinked to the repo's provisioning/ dir by install.sh.
# helpers.sh only defines functions, and the doing/ask_yes_or_no helpers it
# calls are loaded from ~/.functions before the alias files.
[ -r ~/.provisioning/mac/helpers.sh ] && source ~/.provisioning/mac/helpers.sh
