#!/usr/bin/env bash

# Git aliases — pared down to the ones actually used day to day.
# Reference: https://git-scm.com/docs/

# ── Custom functions ───────────────────────────────────────────────

# Detect the repo's default branch (main, master, etc.) so branch-specific
# aliases work in any repo regardless of naming convention.
git_main_branch() {
    command git rev-parse --git-dir &>/dev/null || return
    local ref
    for ref in refs/{heads,remotes/{origin,upstream}}/{main,master,trunk}; do
        if command git show-ref -q --verify "$ref"; then
            echo "${ref##*/}"
            return
        fi
    done
    echo master
}

# Commit with a message arg, or prompt for one if none given.
gitcommit() {
    if [ $# -eq 0 ]; then
        echo -n "Enter a commit message: "
        read message
    else
        message="$@";
    fi;

    git commit -m "$message"
    echo "Commit:" \"$message\"
}

# Scrub a file from all of git history (use with care).
removefromgithistory() {
    echo -n "Type the path to the file to remove from git history: "
    read message
    git filter-branch --force --index-filter 'git rm --cached --ignore-unmatch '$message'' --prune-empty --tag-name-filter cat -- --all
    echo "Done."
}

# Rebase the current branch on a freshly-pulled develop.
updatefromdevelop() {
    git checkout develop && git pull && git checkout - && git rebase develop
}

# Nuke all local changes and untracked files back to HEAD.
alias nah='git reset --hard && git clean -df && git checkout HEAD'

# ── Core ───────────────────────────────────────────────────────────
alias g='git'
alias gst='git status'
alias gss='git status -s'

# ── Staging ────────────────────────────────────────────────────────
alias ga='git add'
alias gaa='git add --all'
alias gap='git add --patch'

# ── Commit ─────────────────────────────────────────────────────────
alias gc='gitcommit'                       # custom: message arg or prompt
alias gcmsg='git commit -m'                # quick one-liner commit
alias gca='git commit -v --amend'          # amend (edit message)
alias gcn='git commit -v --no-edit --amend'  # amend, keep message

# ── Branch / switch / checkout ─────────────────────────────────────
alias gb='git branch'
alias gba='git branch -a'
alias gbd='git branch -d'
alias gco='git checkout'
alias gcb='git checkout -b'
alias gcm='git checkout $(git_main_branch)' # go to main/master (classic)
alias gsw='git switch'                      # modern: switch branches
alias gswc='git switch -c'                  # modern: create + switch
alias gswm='git switch $(git_main_branch)'  # go to main/master (modern)

# ── Restore / reset ────────────────────────────────────────────────
alias grs='git restore'                     # discard working-tree changes
alias grss='git restore --staged'           # unstage
alias grh='git reset HEAD'                  # unstage (classic)
alias grhh='git reset --hard'               # discard everything to HEAD

# ── Diff / log ─────────────────────────────────────────────────────
alias gd='git diff'
alias gdca='git diff --cached'              # staged diff
alias glo='git log --oneline --decorate'
alias glog='git log --oneline --decorate --graph'
alias glol="git log --graph --pretty='%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit"

# ── Fetch / pull / push ────────────────────────────────────────────
alias gf='git fetch'
alias gfa='git fetch --all --prune'
alias gl='git pull'
alias gup='git pull --rebase'
alias gp='git push'
alias gpf='git push --force-with-lease'     # safe force-push
alias gpu='git push -u origin HEAD'         # push + set upstream

# ── Merge / rebase / cherry-pick ───────────────────────────────────
alias gm='git merge'
alias grb='git rebase'
alias grbi='git rebase -i'
alias grbm='git rebase $(git_main_branch)'
alias grbc='git rebase --continue'
alias grba='git rebase --abort'
alias gcp='git cherry-pick'

# ── Stash ──────────────────────────────────────────────────────────
alias gsta='git stash'
alias gstp='git stash pop'
alias gstl='git stash list'

# ── History rewrite helper ─────────────────────────────────────────
alias grmh='removefromgithistory'

# ── GitHub CLI account switching ───────────────────────────────────
# gh auth switch flips the active account globally, governing gh API calls
# and HTTPS git auth — run ghwho before pushing if unsure.
alias ghwho='gh auth status'
alias ghsw='gh auth switch'
