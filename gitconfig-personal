[core]
	autocrlf = input
	excludesfile = ~/.gitignore
	sshCommand = ssh -i ~/.ssh/id_rsa_personal
[color]
	ui = true
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f

[credential]
        helper = store
